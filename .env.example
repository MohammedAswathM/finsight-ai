# =============================================================================
# FinSight AI — Environment Variables
# =============================================================================
# Copy this file to `.env` (same directory) and fill in the values below.
# Never commit `.env` — it is gitignored.
# -----------------------------------------------------------------------------

# --- REQUIRED ---------------------------------------------------------------

# Groq — free LLM inference (no credit card).
# Get a key: https://console.groq.com/keys
# Used by: planner, evaluator, synthesizer, RAG agent, SQL agent.
GROQ_API_KEY=gsk_your_groq_key_here

# Groq model — override if Groq deprecates the default.
# Current prod: llama-3.3-70b-versatile (replaces decommissioned llama3-70b-8192).
# See https://console.groq.com/docs/models for the live list.
GROQ_MODEL=llama-3.3-70b-versatile


# --- OPTIONAL ---------------------------------------------------------------

# OpenAI — ONLY required for the multimodal (image-upload) demo query
# using GPT-4V. The system works end-to-end without this key.
OPENAI_API_KEY=

# NewsAPI — optional. If blank, we fall back to Yahoo Finance RSS
# (feedparser), which is free and needs no key.
NEWSAPI_KEY=


# --- LOCAL SERVICES ---------------------------------------------------------
# These default correctly; only change if you move services around.

# MLflow tracking URI.
# LEAVE BLANK to use local file store at ./mlruns (recommended — no server needed).
# Set to http://127.0.0.1:5000 ONLY if you're running `mlflow server` separately.
MLFLOW_TRACKING_URI=

# ChromaDB persistence path (matches retrieval/vectorstore.py).
CHROMA_DB_PATH=./chroma_db
